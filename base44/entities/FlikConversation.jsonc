{
  "name": "FlikConversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Conversation title"
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "Array of messages in the conversation"
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of last message"
    }
  },
  "required": [
    "title",
    "messages"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    }
  }
}